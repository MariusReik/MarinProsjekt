# Barentswatch API credentials — register a client at https://www.barentswatch.no/minside/
# Copy this file to .env and fill in values. Never commit .env.
BW_CLIENT_ID=
BW_CLIENT_SECRET=

# Postgres connection (default matches infra/docker-compose.yml)
DATABASE_URL=postgres://marin:marin@localhost:5432/marin

# Optional overrides (defaults: Vestland box from the decision log)
# BBOX_MIN_LAT=59.0
# BBOX_MAX_LAT=62.5
# BBOX_MIN_LON=3.5
# BBOX_MAX_LON=8.0
# AIS_STREAM_URL=https://live.ais.barentswatch.no/v1/combined?modelType=Full&modelFormat=Json

# Fiskehelse aquaculture localities (issue #11). Same client credentials as AIS,
# but the client must be authorised for the 'api' scope in addition to 'ais'.
# LOCALITIES_URL=https://www.barentswatch.no/bwapi/v1/geodata/fishhealth/localities
# LOCALITIES_SCOPE=api
# LOCALITIES_REFRESH_MS=86400000   # 24h; localities change slowly
